#!/usr/bin/env sh
# Lina pre-commit hook — slop detector
# See /docs/writing-style.md for the rules and thresholds.
# To bypass in an emergency: LINA_SKIP_SLOP_CHECK=1 git commit ...

set -e

if [ "$LINA_SKIP_SLOP_CHECK" = "1" ]; then
  echo "[slop-check] Skipped (LINA_SKIP_SLOP_CHECK=1)."
  exit 0
fi

# Find staged English source blog posts (ignore generated locale directories)
STAGED_BLOG_FILES=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^blog/[^/]+/index\.html$' || true)

if [ -z "$STAGED_BLOG_FILES" ]; then
  exit 0
fi

echo "[slop-check] Running on:"
echo "$STAGED_BLOG_FILES" | sed 's/^/  /'

STATUS=0
node scripts/slop-check.js $STAGED_BLOG_FILES || STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo ""
  echo "[slop-check] Commit blocked. Fix the ERROR findings above, or bypass"
  echo "              with: LINA_SKIP_SLOP_CHECK=1 git commit ..."
  exit 1
fi

exit 0
